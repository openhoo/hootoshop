{
  "name": "hootoshop",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "description": "A browser-based image editor for cropping, resizing, adjusting, and exporting images locally.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openhoo/hootoshop.git"
  },
  "bugs": {
    "url": "https://github.com/openhoo/hootoshop/issues"
  },
  "homepage": "https://github.com/openhoo/hootoshop#readme",
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "biome:check": "biome ci --error-on-warnings .",
    "biome:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "check": "bun run biome:check && bun run typecheck && bun run test:coverage && bun run build",
    "audit": "bun audit",
    "hooks:install": "if git rev-parse --git-dir >/dev/null 2>&1; then git config core.hooksPath .githooks; fi",
    "prepare": "bun run hooks:install",
    "verify": "bun run check && bun run audit"
  },
  "dependencies": {
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@openhoo/hooversion": "0.1.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "postcss": "8.5.15",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "trustedDependencies": [
    "sharp"
  ]
}
